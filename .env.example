# =============================================================================
# GIROS-BOT — Variables de Entorno
# Copiar a .env y completar los valores. NUNCA commitear .env al repositorio.
# =============================================================================

# LLM — Google Gemini
GOOGLE_API_KEY=

# Tavily Search (contexto de mercado en Scout_Agent)
# Obtener en: https://tavily.com — Free tier: 1000 requests/mes
TAVILY_API_KEY=

# GitHub Integration
GITHUB_TOKEN=
GITHUB_REPO_OWNER=girosmedia
GITHUB_REPO_NAME=girosmedia-web-new

# Webhooks RRSS
SOCIAL_WEBHOOK_URL=

# PostgreSQL (SQLAlchemy async)
# Formato: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
# - Desarrollo local:  host = localhost
# - Docker Compose:    host = nombre del servicio (ej: db)
# Setup inicial:  sudo -u postgres psql -f scripts/setup_postgres.sql
DATABASE_URL=postgresql+asyncpg://giros_bot:giros_bot_2026@localhost:5432/giros_bot

# App
APP_ENV=development  # development | production
LOG_LEVEL=INFO

# =============================================================================
# WHATSAPP BUSINESS (Webhook Triage Agent)
# =============================================================================
# Meta Developer Portal → App → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=91234567890
WHATSAPP_API_TOKEN=dasvsfbrwyhnytnjmuy
WHATSAPP_VERIFY_TOKEN=giros_webhook_verify_2026
WHATSAPP_API_VERSION=v21.0

# Agendamiento (proveedor intercambiable: calendly | google_calendar)
SCHEDULING_PROVIDER=calendly
SCHEDULING_URL=https://calendly.com/girosmedia/reunion

# Notificaciones de leads
LEAD_NOTIFICATION_EMAIL=

# Cloudflare R2 (almacenamiento de imágenes watermarked para RRSS)
# Crear credenciales en: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=
