# =============================================================================
# GIROS-BOT — Variables de Entorno
# Copiar a .env y completar los valores. NUNCA commitear .env al repositorio.
# =============================================================================

# LLM — Google Gemini
GOOGLE_API_KEY=

# Tavily Search (contexto de mercado en Scout_Agent)
# Obtener en: https://tavily.com — Free tier: 1000 requests/mes
TAVILY_API_KEY=

# GitHub Integration
GITHUB_TOKEN=
GITHUB_REPO_OWNER=girosmedia
GITHUB_REPO_NAME=girosmedia-web-new

# Webhooks RRSS
SOCIAL_WEBHOOK_URL=

# PostgreSQL (SQLAlchemy async)
# Formato: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
# Setup inicial:  sudo -u postgres psql -f scripts/setup_postgres.sql
DATABASE_URL=postgresql+asyncpg://giros_bot:giros_bot_2026@localhost:5432/giros_bot

# App
APP_ENV=development  # development | production
LOG_LEVEL=INFO
